# Copy this file to `.env` for local development.
# On Vercel, set the same names under Project → Settings → Environment Variables.

# --- Public (safe to expose to the browser) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# --- Server-only (NEVER prefix with VITE_) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — only needed for Deen Buddy AI chat.
# Replace with your own OpenAI / Gemini / OpenRouter key if you self-host AI.
LOVABLE_API_KEY=
